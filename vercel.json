{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "app/api/pipeline/run/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/cleanup/route.ts": {
      "maxDuration": 60
    }
  }
}
