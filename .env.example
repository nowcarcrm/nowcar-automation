# =============================================================================
# nowcar-automation — 환경변수 템플릿 (.env.example)
# -----------------------------------------------------------------------------
# 이 파일은 시크릿이 없는 "어떤 변수가 필요한가" 문서입니다. 실제 값은 절대
# 커밋하지 마세요(.gitignore 가 .env / .env.local 을 무시합니다). 운영 값은
# Vercel 대시보드 > Settings > Environment Variables 에 설정합니다.
#
# 표기:
#   [필수]  없으면 해당 기능이 throw/중단됩니다.
#   [선택]  미설정 시 안전한 기본값으로 동작합니다.
#   [토글]  "true" 일 때만 켜집니다(그 외 값/미설정이면 꺼짐).
#   [자동]  Vercel 이 주입합니다 — 직접 설정하지 마세요.
# =============================================================================

# ---- 코어 / 인증 ------------------------------------------------------------
# [필수] 모든 cron(/api/cron/*) 과 /api/content/*, /api/youtube/check, /api/test
#        의 게이트. 미설정 시 외부 HTTP 호출이 전부 401 로 차단됩니다(= 다운로드/
#        발행이 멈춤). 길고 무작위한 값으로(예: openssl rand -hex 32). 쿼리(?secret=)
#        로도 쓰이므로 URL 안전 문자 권장.
CRON_SECRET=

# ---- AI / STT ---------------------------------------------------------------
ANTHROPIC_API_KEY=            # [필수] Claude(콘텐츠 생성). 모델 claude-sonnet-4-6
OPENAI_API_KEY=               # [필수] Whisper STT(자막 추출)

# ---- YouTube ----------------------------------------------------------------
YOUTUBE_API_KEY=              # [필수] YouTube Data API v3(신규 영상 감지)
YOUTUBE_CHANNEL_ID=           # [필수] 나우카 채널 ID
# [선택] ytdl 봇차단 우회용 로그인 쿠키 JSON 배열(한 줄 minified). 만료 시 갱신.
#        로컬 워커(사무실 PC)가 주로 사용. 자세한 추출법은 lib/storage.ts 주석 참고.
YOUTUBE_COOKIES=

# ---- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=         # [필수] 프로젝트 URL(공개)
NEXT_PUBLIC_SUPABASE_ANON_KEY=    # [필수] anon 키(공개, RLS 로 보호됨)
# [필수] service_role 키 — RLS 우회. 서버 전용. 절대 클라이언트/공개 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# ---- 이메일(Gmail SMTP) -----------------------------------------------------
EMAIL_USER=                   # [필수] 발신 Gmail 주소
EMAIL_PASS=                   # [필수] Gmail 앱 비밀번호(일반 비번 아님)
TISTORY_EMAIL=                # [선택] 티스토리 이메일-발행 수신 주소

# ---- Meta (Instagram / Facebook / Threads) ----------------------------------
META_ACCESS_TOKEN=                # [필수] 장기 토큰(자동 갱신 대상). DB system_tokens 에서도 로드됨.
META_APP_ID=                      # [필수] fb_exchange_token 자동 갱신용
META_APP_SECRET=                  # [필수] fb_exchange_token 자동 갱신용
INSTAGRAM_BUSINESS_ACCOUNT_ID=    # [필수] 인스타 릴스 발행 대상 계정
FACEBOOK_PAGE_ID=                 # [필수] 페북 페이지
THREADS_USER_ID=                  # [필수] 스레드 사용자 ID
THREADS_ACCESS_TOKEN=             # [필수] 스레드 토큰
AUTO_PUBLISH_INSTAGRAM=           # [토글] "true" 면 인스타 자동발행
AUTO_PUBLISH_FACEBOOK=            # [토글] "true" 면 페북 자동발행
AUTO_PUBLISH_THREADS=             # [토글] "true" 면 스레드 자동발행

# ---- Naver Cafe -------------------------------------------------------------
# 주의: 현재 카페 자동발행은 코드 레벨 kill switch(NAVER_CAFE_AUTO_PUBLISH_PAUSED)
#       로 일시정지 상태입니다(999 차단). 계정 정상화 전까지 켜지 마세요.
NAVER_CLIENT_ID=              # [필수*] OAuth 클라이언트 ID  (*카페 사용 시)
NAVER_CLIENT_SECRET=          # [필수*] OAuth 클라이언트 시크릿
NAVER_REFRESH_TOKEN=          # [필수*] 액세스 토큰 재발급용 refresh token
NAVER_CAFE_CLUB_ID=           # [필수*] 카페 club id
NAVER_CAFE_MENU_ID=           # [필수*] 카페 게시판 menu id
AUTO_PUBLISH_NAVER_CAFE=      # [토글] "true" + kill switch 해제 시 카페 발행
NAVER_CAFE_FORCE_RESUME=      # [토글] "true" 면 코드 kill switch 를 무시하고 재개(긴급 탈출구)

# ---- 티스토리 ---------------------------------------------------------------
AUTO_PUBLISH_TISTORY=         # [토글] "true" 면 티스토리 이메일-발행 시도

# ---- Google Drive (다운로드 우회 소스) --------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=  # [선택] 서비스 계정 JSON(한 줄). 운영자가 mp4 를 Drive 에 올릴 때 사용.
GDRIVE_SOURCE_FOLDER_ID=      # [선택] {videoId}.mp4 를 찾을 Drive 폴더 ID

# ---- 튜너블(선택, 기본값 있음) ----------------------------------------------
DETECT_MAX_AGE_DAYS=          # [선택] 발행 윈도우(일). 기본 14. 옛 영상 재발행 차단.
MAX_SHORT_PUBLISH_SECONDS=    # [선택] Meta 발행 최대 길이(초). 기본 120. 롱폼 제외.
MAX_STT_SECONDS=             # [선택] Whisper STT 최대 길이(초). 비용 상한.
LOCAL_WORKER_GRACE_MINUTES=  # [선택] 감지 후 로컬 워커 우선 양보 시간(분). Vercel ytdl 폴백 지연.
PUBLISH_PENDING_TTL_MINUTES= # [선택] pending 발행 정리 TTL(분). 기본 20.

# ---- Vercel 자동 주입 (설정하지 말 것) --------------------------------------
# VERCEL_URL              # [자동] 현재 배포 호스트
# VERCEL_GIT_COMMIT_SHA   # [자동] 실행 커밋 SHA(/api/test 배포 감지에 사용)
